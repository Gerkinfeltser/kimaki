{
  "name": "@kimaki/opencode-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode plugin for Claude Pro/Max subscription support via Anthropic OAuth",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/kimaki",
    "directory": "opencode-kimaki-plugin"
  },
  "keywords": [
    "opencode",
    "plugin",
    "anthropic",
    "claude",
    "oauth",
    "kimaki"
  ],
  "dependencies": {
    "kimaki": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.3.0"
  }
}
